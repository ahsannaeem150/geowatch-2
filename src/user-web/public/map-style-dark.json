{
  "version": 8,
  "name": "GeoWatch Dark",
  "metadata": { "maputnik:renderer": "mbgljs" },
  "center": [0, 20],
  "zoom": 2,
  "bearing": 0,
  "pitch": 0,
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "http://localhost:8080/tiles"
    }
  },
  "sprite": "",
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "layers": [
    { "id": "background", "type": "background", "paint": { "background-color": "#1a1a1a" }},

    { "id": "water", "type": "fill", "source": "openmaptiles", "source-layer": "water", "filter": ["==", "$type", "Polygon"], "paint": { "fill-color": "#1c2636", "fill-outline-color": "#1e2a3a" }},
    { "id": "waterway", "type": "line", "source": "openmaptiles", "source-layer": "waterway", "filter": ["==", "$type", "LineString"], "layout": { "visibility": "visible" }, "paint": { "line-color": "#1e2a3a", "line-width": 1 }},
    { "id": "waterway-river", "type": "line", "source": "openmaptiles", "source-layer": "waterway", "minzoom": 10, "filter": ["all", ["==", "$type", "LineString"], ["==", "class", "river"]], "layout": { "visibility": "visible" }, "paint": { "line-color": "#1e2a3a", "line-width": ["interpolate", ["linear"], ["zoom"], 10, 1, 16, 3] }},

    { "id": "landuse-residential", "type": "fill", "source": "openmaptiles", "source-layer": "landuse", "filter": ["==", "class", "residential"], "paint": { "fill-color": "#252525" }},
    { "id": "landuse-industrial", "type": "fill", "source": "openmaptiles", "source-layer": "landuse", "filter": ["==", "class", "industrial"], "paint": { "fill-color": "#222222" }},
    { "id": "landuse-commercial", "type": "fill", "source": "openmaptiles", "source-layer": "landuse", "filter": ["==", "class", "commercial"], "paint": { "fill-color": "#242424" }},
    { "id": "landuse-park", "type": "fill", "source": "openmaptiles", "source-layer": "landuse", "filter": ["==", "class", "park"], "paint": { "fill-color": "#1f2f1f" }},
    { "id": "landuse-cemetery", "type": "fill", "source": "openmaptiles", "source-layer": "landuse", "filter": ["==", "class", "cemetery"], "paint": { "fill-color": "#222222" }},
    { "id": "landuse-hospital", "type": "fill", "source": "openmaptiles", "source-layer": "landuse", "filter": ["==", "class", "hospital"], "paint": { "fill-color": "#2a2020" }},
    { "id": "landuse-school", "type": "fill", "source": "openmaptiles", "source-layer": "landuse", "filter": ["==", "class", "school"], "paint": { "fill-color": "#242424" }},
    { "id": "landuse-pitch", "type": "fill", "source": "openmaptiles", "source-layer": "landuse", "filter": ["==", "class", "pitch"], "paint": { "fill-color": "#1e2e1e" }},
    { "id": "landcover-wood", "type": "fill", "source": "openmaptiles", "source-layer": "landcover", "filter": ["==", "class", "wood"], "paint": { "fill-color": "#1f2a1f", "fill-opacity": 0.4 }},
    { "id": "landcover-grass", "type": "fill", "source": "openmaptiles", "source-layer": "landcover", "filter": ["==", "class", "grass"], "paint": { "fill-color": "#1f2a1f", "fill-opacity": 0.3 }},

    { "id": "boundary-land-level-2", "type": "line", "source": "openmaptiles", "source-layer": "boundary", "filter": ["==", "admin_level", 2], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#444", "line-width": 1.5 }},
    { "id": "boundary-land-level-4", "type": "line", "source": "openmaptiles", "source-layer": "boundary", "filter": ["==", "admin_level", 4], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#3a3a3a", "line-width": 1, "line-dasharray": [3, 2] }},

    { "id": "transportation-motorway", "type": "line", "source": "openmaptiles", "source-layer": "transportation", "minzoom": 5, "filter": ["all", ["==", "$type", "LineString"], ["==", "class", "motorway"]], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#555", "line-width": ["interpolate", ["linear"], ["zoom"], 5, 0.5, 10, 2, 16, 6] }},
    { "id": "transportation-trunk", "type": "line", "source": "openmaptiles", "source-layer": "transportation", "minzoom": 5, "filter": ["all", ["==", "$type", "LineString"], ["==", "class", "trunk"]], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#505050", "line-width": ["interpolate", ["linear"], ["zoom"], 5, 0.5, 10, 1.5, 16, 5] }},
    { "id": "transportation-primary", "type": "line", "source": "openmaptiles", "source-layer": "transportation", "minzoom": 7, "filter": ["all", ["==", "$type", "LineString"], ["==", "class", "primary"]], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#484848", "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.5, 10, 1.5, 16, 5] }},
    { "id": "transportation-secondary", "type": "line", "source": "openmaptiles", "source-layer": "transportation", "minzoom": 9, "filter": ["all", ["==", "$type", "LineString"], ["==", "class", "secondary"]], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#404040", "line-width": ["interpolate", ["linear"], ["zoom"], 9, 0.5, 12, 1.5, 16, 4] }},
    { "id": "transportation-tertiary", "type": "line", "source": "openmaptiles", "source-layer": "transportation", "minzoom": 11, "filter": ["all", ["==", "$type", "LineString"], ["==", "class", "tertiary"]], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#383838", "line-width": ["interpolate", ["linear"], ["zoom"], 11, 0.5, 14, 2, 16, 3.5] }},
    { "id": "transportation-minor", "type": "line", "source": "openmaptiles", "source-layer": "transportation", "minzoom": 12, "filter": ["all", ["==", "$type", "LineString"], ["==", "class", "minor"]], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#333", "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.5, 14, 1.5, 16, 3] }},
    { "id": "transportation-residential", "type": "line", "source": "openmaptiles", "source-layer": "transportation", "minzoom": 13, "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "residential", "service", "track"]], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#2e2e2e", "line-width": ["interpolate", ["linear"], ["zoom"], 13, 0.5, 15, 1.5, 16, 2.5] }},
    { "id": "transportation-path", "type": "line", "source": "openmaptiles", "source-layer": "transportation", "minzoom": 14, "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "path", "pedestrian", "footway"]], "layout": { "line-cap": "round", "line-join": "round" }, "paint": { "line-color": "#2a2a2a", "line-width": ["interpolate", ["linear"], ["zoom"], 14, 0.5, 16, 1.5], "line-dasharray": [4, 2] }},
    { "id": "transportation-rail", "type": "line", "source": "openmaptiles", "source-layer": "transportation", "minzoom": 10, "filter": ["all", ["==", "$type", "LineString"], ["==", "class", "rail"]], "layout": { "visibility": "visible" }, "paint": { "line-color": "#444", "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.5, 16, 2] }},

    { "id": "building", "type": "fill", "source": "openmaptiles", "source-layer": "building", "minzoom": 13, "paint": { "fill-color": "#383838", "fill-outline-color": "#444", "fill-opacity": ["interpolate", ["linear"], ["zoom"], 13, 0.3, 16, 0.8] }},

    { "id": "transportation-name", "type": "symbol", "source": "openmaptiles", "source-layer": "transportation_name", "minzoom": 12, "filter": ["==", "$type", "LineString"], "layout": { "text-field": "{name}", "text-font": ["Noto Sans Regular"], "text-size": ["interpolate", ["linear"], ["zoom"], 12, 9, 16, 12], "text-max-width": 8, "symbol-placement": "line", "text-letter-spacing": 0.1 }, "paint": { "text-color": "#999", "text-halo-color": "#1a1a1a", "text-halo-width": 1.5 }},

    { "id": "water-name", "type": "symbol", "source": "openmaptiles", "source-layer": "water_name", "minzoom": 3, "filter": ["==", "$type", "Point"], "layout": { "text-field": "{name}", "text-font": ["Noto Sans Regular"], "text-size": 11, "text-letter-spacing": 0.15, "text-max-width": 8 }, "paint": { "text-color": "#4a6a8a", "text-halo-color": "#1a1a1a", "text-halo-width": 1.5 }},
    { "id": "place-country", "type": "symbol", "source": "openmaptiles", "source-layer": "place", "filter": ["==", "class", "country"], "layout": { "text-field": "{name_en}", "text-font": ["Noto Sans Bold"], "text-size": ["interpolate", ["linear"], ["zoom"], 1, 10, 4, 14], "text-transform": "uppercase", "text-letter-spacing": 0.2, "text-max-width": 8 }, "paint": { "text-color": "#888", "text-halo-color": "#1a1a1a", "text-halo-width": 2 }},
    { "id": "place-state", "type": "symbol", "source": "openmaptiles", "source-layer": "place", "minzoom": 3, "filter": ["==", "class", "state"], "layout": { "text-field": "{name_en}", "text-font": ["Noto Sans Regular"], "text-size": 11, "text-transform": "uppercase", "text-letter-spacing": 0.15, "text-max-width": 8 }, "paint": { "text-color": "#777", "text-halo-color": "#1a1a1a", "text-halo-width": 1.5 }},
    { "id": "place-city", "type": "symbol", "source": "openmaptiles", "source-layer": "place", "minzoom": 4, "filter": ["all", ["==", "class", "city"], ["<=", "rank", 8]], "layout": { "text-field": "{name_en}", "text-font": ["Noto Sans Regular"], "text-size": ["interpolate", ["linear"], ["zoom"], 4, 10, 8, 13], "text-max-width": 8 }, "paint": { "text-color": "#aaa", "text-halo-color": "#1a1a1a", "text-halo-width": 1.5 }},
    { "id": "place-town", "type": "symbol", "source": "openmaptiles", "source-layer": "place", "minzoom": 6, "filter": ["==", "class", "town"], "layout": { "text-field": "{name_en}", "text-font": ["Noto Sans Regular"], "text-size": 10, "text-max-width": 8 }, "paint": { "text-color": "#999", "text-halo-color": "#1a1a1a", "text-halo-width": 1.5 }},
    { "id": "place-village", "type": "symbol", "source": "openmaptiles", "source-layer": "place", "minzoom": 9, "filter": ["==", "class", "village"], "layout": { "text-field": "{name_en}", "text-font": ["Noto Sans Regular"], "text-size": 10, "text-max-width": 8 }, "paint": { "text-color": "#888", "text-halo-color": "#1a1a1a", "text-halo-width": 1.5 }},
    { "id": "poi", "type": "symbol", "source": "openmaptiles", "source-layer": "poi", "minzoom": 14, "filter": ["==", "$type", "Point"], "layout": { "text-field": "{name}", "text-font": ["Noto Sans Regular"], "text-size": ["interpolate", ["linear"], ["zoom"], 14, 9, 16, 11], "text-max-width": 8, "text-anchor": "top", "text-offset": [0, 0.8], "icon-size": 0.6 }, "paint": { "text-color": "#bbb", "text-halo-color": "#1a1a1a", "text-halo-width": 1.5 }}
  ],
  "id": "geowatch-dark"
}
