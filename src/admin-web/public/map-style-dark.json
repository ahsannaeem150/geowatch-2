{
  "version": 8,
  "name": "GeoWatch Dark Minimal",
  "metadata": {
    "maputnik:renderer": "mbgljs"
  },
  "center": [
    0,
    20
  ],
  "zoom": 2,
  "bearing": 0,
  "pitch": 0,
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "http://localhost:8080/tiles"
    }
  },
  "sprite": "",
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#0f1117"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": [
        "==",
        "$type",
        "Polygon"
      ],
      "paint": {
        "fill-color": "#14161f",
        "fill-outline-color": "#1a1d29"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": [
        "==",
        "$type",
        "LineString"
      ],
      "layout": {
        "visibility": "visible"
      },
      "paint": {
        "line-color": "#1a1d29",
        "line-width": 1
      }
    },
    {
      "id": "landcover-glacier",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": [
        "==",
        "subclass",
        "glacier"
      ],
      "paint": {
        "fill-color": "#161822",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landuse-residential",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": [
        "==",
        "class",
        "residential"
      ],
      "paint": {
        "fill-color": "#13151c"
      }
    },
    {
      "id": "landuse-industrial",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": [
        "==",
        "class",
        "industrial"
      ],
      "paint": {
        "fill-color": "#11131a"
      }
    },
    {
      "id": "landuse-cemetery",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": [
        "==",
        "class",
        "cemetery"
      ],
      "paint": {
        "fill-color": "#11131a"
      }
    },
    {
      "id": "landuse-hospital",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": [
        "==",
        "class",
        "hospital"
      ],
      "paint": {
        "fill-color": "#11131a"
      }
    },
    {
      "id": "landuse-school",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": [
        "==",
        "class",
        "school"
      ],
      "paint": {
        "fill-color": "#11131a"
      }
    },
    {
      "id": "landuse-park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": [
        "==",
        "class",
        "park"
      ],
      "paint": {
        "fill-color": "#11131a"
      }
    },
    {
      "id": "landuse-pitch",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": [
        "==",
        "class",
        "pitch"
      ],
      "paint": {
        "fill-color": "#0e1015"
      }
    },
    {
      "id": "boundary-land-level-4",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": [
        "==",
        "admin_level",
        4
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-color": "#2a2e3b",
        "line-width": 1,
        "line-dasharray": [
          3,
          2
        ]
      }
    },
    {
      "id": "boundary-land-level-2",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": [
        "==",
        "admin_level",
        2
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-color": "#3a3e4b",
        "line-width": 1.5
      }
    },
    {
      "id": "boundary-water",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": [
        "==",
        "maritime",
        1
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#1a1d29",
        "line-width": 1,
        "line-dasharray": [
          4,
          2
        ]
      }
    },
    {
      "id": "transportation-motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "all",
        [
          "==",
          "$type",
          "LineString"
        ],
        [
          "==",
          "class",
          "motorway"
        ]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-color": "#2a2e3b",
        "line-width": 1
      }
    },
    {
      "id": "transportation-trunk",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "all",
        [
          "==",
          "$type",
          "LineString"
        ],
        [
          "==",
          "class",
          "trunk"
        ]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-color": "#252935",
        "line-width": 0.8
      }
    },
    {
      "id": "transportation-primary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "all",
        [
          "==",
          "$type",
          "LineString"
        ],
        [
          "==",
          "class",
          "primary"
        ]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-color": "#222636",
        "line-width": 0.6
      }
    },
    {
      "id": "transportation-secondary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "all",
        [
          "==",
          "$type",
          "LineString"
        ],
        [
          "==",
          "class",
          "secondary"
        ]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-color": "#1e212b",
        "line-width": 0.5
      }
    },
    {
      "id": "transportation-rail",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "all",
        [
          "==",
          "$type",
          "LineString"
        ],
        [
          "==",
          "class",
          "rail"
        ]
      ],
      "layout": {
        "visibility": "visible"
      },
      "paint": {
        "line-color": "#2a2e3b",
        "line-width": 0.5
      }
    },
    {
      "id": "water-name",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "water_name",
      "minzoom": 3,
      "filter": [
        "==",
        "$type",
        "Point"
      ],
      "layout": {
        "text-field": "{name}",
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": 11,
        "text-letter-spacing": 0.15,
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#3a4a5a",
        "text-halo-color": "#0f1117",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-country",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": [
        "==",
        "class",
        "country"
      ],
      "layout": {
        "text-field": "{name_en}",
        "text-font": [
          "Noto Sans Bold"
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          1,
          10,
          4,
          14
        ],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.2,
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#6b7080",
        "text-halo-color": "#0f1117",
        "text-halo-width": 2
      }
    },
    {
      "id": "place-state",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 3,
      "filter": [
        "==",
        "class",
        "state"
      ],
      "layout": {
        "text-field": "{name_en}",
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": 11,
        "text-transform": "uppercase",
        "text-letter-spacing": 0.15,
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#5a5e6a",
        "text-halo-color": "#0f1117",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 4,
      "filter": [
        "all",
        [
          "==",
          "class",
          "city"
        ],
        [
          "<=",
          "rank",
          8
        ]
      ],
      "layout": {
        "text-field": "{name_en}",
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          4,
          10,
          8,
          13
        ],
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#8b8f9a",
        "text-halo-color": "#0f1117",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-town",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 6,
      "filter": [
        "==",
        "class",
        "town"
      ],
      "layout": {
        "text-field": "{name_en}",
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": 10,
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#7a7e8a",
        "text-halo-color": "#0f1117",
        "text-halo-width": 1.5
      }
    }
  ],
  "id": "geowatch-dark-minimal"
}
